# devbox-bridge — config di esempio
# Copia in `config.yaml` ed edita.
# Per attivare un progetto, decommenta il blocco e verifica che il path esista
# (i path qui sono presi dai 14 progetti del global context ~/.claude/CLAUDE.md;
#  se la directory non esiste sulla devbox, lascia commentato).

server:
  bind: "127.0.0.1:8765"
  log_level: "INFO"
  log_dir: "/var/log/devbox-bridge"

auth:
  # Hash sha256 del bearer token. Il file viene generato da deploy/install.sh
  # in /etc/devbox-bridge/token.sha256 (chmod 600, owner devbox-bridge).
  token_hash_file: "/etc/devbox-bridge/token.sha256"

# Blocco opzionale — tutti i campi hanno default sensati, puoi omettere
# l'intera sezione `audit:` e funziona uguale.
audit:
  # log_dir: default = <server.log_dir>/audit
  # log_dir: "/var/log/devbox-bridge/audit"
  rotation_size_mb: 50    # rotazione + gzip oltre questa dimensione
  retention_days: 90      # file .gz più vecchi vengono eliminati al boot
  audit_reads: false      # se true logga anche read_file/list_directory/git_status/...

projects:

  # ─────────────────────────────────────────────────────────────────
  # Progetto attivo: devbox-bridge stesso (utile per dogfooding)
  # ─────────────────────────────────────────────────────────────────
  devbox-bridge:
    path: "/home/hypn0/projects/devbox-bridge"
    write_enabled: false
    allow_push: false
    test_command: "pytest -x --tb=short"
    lint_command: "ruff check ."
    build_command: null
    command_whitelist:
      - "^pytest( .*)?$"
      - "^ruff( .*)?$"
      - "^mypy( .*)?$"
    env_passthrough: []

  # ─────────────────────────────────────────────────────────────────
  # I 14 progetti del global context — placeholder.
  # Decommenta SOLO dopo aver verificato che il path esista sulla devbox.
